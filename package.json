{
  "name": "send-it",
  "productName": "Send It",
  "version": "1.0.1",
  "description": "A beautiful, dead-simple notepad that syncs instantly between your machines over the local network. No cloud, no accounts, no terminal.",
  "main": "src/main.js",
  "author": "Ben",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ben.sendit",
    "productName": "Send It",
    "files": [
      "src/**/*",
      "build/icon.*",
      "build/trayTemplate*.png"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "Send It"
    }
  }
}
